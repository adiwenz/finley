{
  "name": "finley",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/engine",
    "packages/rules",
    "packages/app"
  ],
  "scripts": {
    "sandcastle": "npx tsx .sandcastle/new_flow/main.ts",
    "dev": "npm run dev -w @finley/app",
    "build": "npm run build -w @finley/app",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check:purity": "node scripts/check-engine-purity.mjs",
    "check": "npm run check:purity && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "@vercel/sandbox": "^2.7.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  }
}
